{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "CMake: Configure",
      "type": "shell",
      "command": "& 'C:\\Program Files (x86)\\Microsoft Visual Studio\\2019\\BuildTools\\Common7\\IDE\\CommonExtensions\\Microsoft\\CMake\\CMake\\bin\\cmake.exe' -B build -G 'Visual Studio 16 2019' -A Win32",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Build: RavenShield",
      "type": "shell",
      "command": "& 'C:\\Program Files (x86)\\Microsoft Visual Studio\\2019\\BuildTools\\Common7\\IDE\\CommonExtensions\\Microsoft\\CMake\\CMake\\bin\\cmake.exe' --build build --config Release --target RavenShield",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Stage: Rebuilt Runtime",
      "type": "shell",
      "command": "$stage = '${workspaceFolder}\\build\\runtime-test\\system'; $retail = '${workspaceFolder}\\retail\\system'; $rebuilt = '${workspaceFolder}\\build\\bin'; $middleware = @('binkw32.dll','eax.dll','MFC71.dll','msvcp71.dll','msvcr71.dll','MSVCRT.dll','ogg.dll','OpenAL32.dll','vorbis.dll','vorbisfile.dll'); $assetPatterns = @('*.u','*.int','*.ini','*.bmp','*.dat','*.list'); $assetDirs = @('EditorRes','Res'); New-Item -ItemType Directory -Force -Path $stage | Out-Null; Get-ChildItem -Path $stage -Force | Remove-Item -Recurse -Force; foreach ($pattern in $assetPatterns) { Get-ChildItem -Path $retail -Filter $pattern -File | Copy-Item -Destination $stage -Force; } foreach ($dir in $assetDirs) { $src = Join-Path $retail $dir; if (Test-Path $src) { Copy-Item $src $stage -Recurse -Force; } } foreach ($file in $middleware) { $src = Join-Path $retail $file; if (Test-Path $src) { Copy-Item $src $stage -Force; } } Copy-Item (Join-Path $rebuilt '*') $stage -Force; Write-Host 'Staged rebuilt runtime at build/runtime-test/system/ without retail game DLLs.'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Build: RavenShield",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run: RavenShield",
      "type": "shell",
      "command": "Start-Process '${workspaceFolder}\\build\\runtime-test\\system\\RavenShield.exe' -WorkingDirectory '${workspaceFolder}\\build\\runtime-test\\system'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Stage: Rebuilt Runtime",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Run: RavenShield (Unattended)",
      "type": "shell",
      "command": "Start-Process '${workspaceFolder}\\build\\runtime-test\\system\\RavenShield.exe' -ArgumentList '-UNATTENDED' -WorkingDirectory '${workspaceFolder}\\build\\runtime-test\\system'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": "Stage: Rebuilt Runtime",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Stop: RavenShield",
      "type": "shell",
      "command": "Stop-Process -Name 'RavenShield' -Force -ErrorAction SilentlyContinue; Write-Host 'Stopped'",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Docusaurus: Dev Server",
      "type": "shell",
      "command": "npx docusaurus start --host 0.0.0.0",
      "options": {
        "cwd": "${workspaceFolder}/blog"
      },
      "isBackground": true,
      "problemMatcher": [],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      }
    }
  ]
}
