# =============================================================================
# Ravenshield Decompilation Project - .gitignore
# =============================================================================

# --- Retail game binaries (large, copyrighted, do not redistribute) ---
retail/

# --- SDK (copyrighted third-party code, do not redistribute) ---
# Contributors must source the Raven Shield SDK independently
sdk/

# --- Ghidra project databases (huge, machine-specific) ---
ghidra/project/
ghidra/exports/
*.gpr
*.rep

# --- Build output ---
build/
out/
*.obj
*.pdb
*.ilk
*.exp
*.lib
*.pch
*.idb
*.ncb
*.suo
*.user
*.log

# --- Temporary / working files ---
build_errors.txt
*.bak

# --- Tools (large binaries) ---
tools/toolchain/
tools/extlibs/

# --- Blog build output ---
blog/node_modules/
blog/.docusaurus/
blog/build/

# --- OS / Editor artifacts ---
.vs/
.vscode/settings.json
*.swp
*~
Thumbs.db
Desktop.ini
.DS_Store

# --- Python ---
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Scratch/temp scripts
tmp_*.py
fix_*.py
test_*.cpp
diag_*.cpp
*.i
